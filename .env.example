# ── Environment Variables Template ────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# REQUIRED markers below indicate variables that MUST be set before going
# live. OPTIONAL variables can stay blank and the site still works (with
# the named feature disabled or using a default).
# ─────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════
# SITE IDENTITY
# ══════════════════════════════════════════════════════════════════════════

# Site name — used everywhere the clinic/project name appears dynamically.
# Email subjects, from_name, page titles, cookie banner copy, JSON-LD.
# Change once per client and every reference updates automatically.
# REQUIRED
PUBLIC_SITE_NAME=Your Clinic Name

# Site URL — used for canonical tags and OG meta.
# REQUIRED
PUBLIC_SITE_URL=https://yourclinic.co.uk


# ══════════════════════════════════════════════════════════════════════════
# TRACKING / ANALYTICS — Cookie consent + GA4 + Google Ads
# ══════════════════════════════════════════════════════════════════════════
# At least ONE of PUBLIC_GTM_ID or PUBLIC_GTAG_ID must be set or analytics
# will not load. PUBLIC_ prefix bakes the value into static HTML at build.

# Google Tag Manager container ID — preferred mode (GTM-only).
# Find: GTM → Admin → Container Settings (e.g. GTM-XXXXXXX)
# REQUIRED (or use PUBLIC_GTAG_ID instead — never both)
PUBLIC_GTM_ID=

# Google tag ID (GA4 Measurement ID for direct gtag.js mode — no GTM).
# Find: GA4 → Admin → Data Streams → Web stream → Measurement ID
# Use ONLY when you do NOT have GTM. If both are set, GTM takes precedence.
# REQUIRED if PUBLIC_GTM_ID is blank — otherwise OPTIONAL
PUBLIC_GTAG_ID=

# Browser-side GA4 ID — legacy fallback for components that read the public
# measurement ID directly (e.g. inline GA4 snippets). Match it to PUBLIC_GTAG_ID.
# REQUIRED
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Ads Conversion ID (AW-XXXXXXXXX).
# Find: Google Ads → Tools → Tag Settings → Conversion linker
# OPTIONAL — only needed for Google Ads remarketing / conversion tracking.
PUBLIC_ADS_CONVERSION_ID=

# GA4 Measurement Protocol API Secret — server-side only (no PUBLIC_).
# Find: GA4 → Admin → Data Streams → select stream → Measurement Protocol API secrets
# REQUIRED — powers /api/book-now and /api/booking-complete server-side events
GA4_API_SECRET=

# GA4 Measurement ID — server-side mirror of PUBLIC_GTAG_ID (no PUBLIC_).
# Used by Cloudflare Pages Functions when forwarding events to GA4.
# REQUIRED
GA4_MEASUREMENT_ID=

# Server-side tracking master switch.
# Set to 'false' to disable /api/book-now + /api/booking-complete endpoints
# (useful for staging or privacy-mode deployments). Default: true.
# OPTIONAL
PUBLIC_SERVER_SIDE_TRACKING=true


# ══════════════════════════════════════════════════════════════════════════
# WEB3FORMS — Contact form
# ══════════════════════════════════════════════════════════════════════════
# Get your access key at https://web3forms.com (Pro plan required for
# `ccemail` + reCAPTCHA verification — ~$8/month).
# PUBLIC_ prefix exposes it to the browser — safe by design.
# The key is bound to the Web3Forms dashboard form; the dashboard's
# "Recipient Emails" field defines the PRIMARY inbox.
# REQUIRED
PUBLIC_WEB3FORMS_KEY=your-access-key-here

# CC list — additional recipients copied on every submission.
# Web3Forms expects field name `ccemail` and SEMICOLON separator.
# (NOT `cc`, NOT `bcc`, NOT `to`. Comma-separated values are auto-
# normalised to semicolons in code so legacy values keep working.)
# PUBLIC_ means it's visible in HTML source — only use email addresses
# that already appear publicly on the contact page.
# REQUIRED
PUBLIC_CLIENT_EMAIL=client@inbox.co.uk; agency@hmdg.co.uk

# Google reCAPTCHA v3 Site Key.
# Register a v3 site at https://www.google.com/recaptcha/admin
# PUBLIC_ prefix exposes the Site Key to the browser — this is correct.
# The SECRET key goes in the Web3Forms dashboard (never in code).
# REQUIRED if Web3Forms reCAPTCHA enforcement is enabled
PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key-here

# Server-side fallback contact email — never appears in HTML.
# REQUIRED
CONTACT_EMAIL=hello@yourclinic.co.uk


# ══════════════════════════════════════════════════════════════════════════
# BOOKING SYSTEM
# ══════════════════════════════════════════════════════════════════════════

# Cliniko (or other) booking system URL — embedded in the booking widget.
# OPTIONAL (clinic-dependent — leave blank if no online booking)
PUBLIC_CLINIKO_BOOKING_URL=

# Universal Booking Tracker — disable specific platforms.
# Comma-separated lowercase keys from the catalog:
#   acuity, calendly, cliniko, jane, phorest, pracsuite, simplybook, timely, youcanbook
# Default: ALL platforms enabled. Example: PUBLIC_BOOKING_DISABLE=acuity,timely
# OPTIONAL
PUBLIC_BOOKING_DISABLE=

# Add custom booking domains not in the catalog (comma-separated).
# Example: PUBLIC_BOOKING_ADDITIONAL_DOMAINS=mybooking.co.uk,otherclinic.com
# OPTIONAL
PUBLIC_BOOKING_ADDITIONAL_DOMAINS=


# ══════════════════════════════════════════════════════════════════════════
# MAPS / API ROUTES
# ══════════════════════════════════════════════════════════════════════════

# Google Maps Embed API Key.
# OPTIONAL — only required if a page embeds Google Maps via the API.
PUBLIC_GOOGLE_MAPS_API_KEY=

# The site's full production URL — used to validate API route request origins.
# Must match the deployed origin exactly (https://, no trailing slash).
# REQUIRED
SITE_ORIGIN=https://yourclinic.co.uk


# ── IMPORTANT: Cloudflare Pages env vars ──────────────────────────────────
# Every PUBLIC_* value above must also be set in:
#   Cloudflare Pages → Settings → Variables and Secrets → BUILD scope
# (NOT Runtime scope — these are baked at build time.)
#
# Cloudflare does NOT auto-rebuild when env vars change. After saving:
#   Deployments → latest deployment → "Retry deployment"
# Without that retry, the form keeps using the old build's values.
