# ── Environment Variables Template ────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────

# Google Analytics
# PUBLIC_ prefix makes the variable available in the browser (Astro rule)
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps Embed API Key
PUBLIC_GOOGLE_MAPS_API_KEY=

# Booking system (Cliniko)
PUBLIC_CLINIKO_BOOKING_URL=

# Site URL (used for canonical tags and OG meta)
PUBLIC_SITE_URL=https://yourclinic.co.uk

# Site name — used everywhere the clinic/project name appears dynamically.
# Email subjects, from_name, page titles, etc. Change this once per client
# and every reference updates automatically.
PUBLIC_SITE_NAME=Your Clinic Name

# Contact email (never expose private emails in markup — use env vars)
# This is server-side only (no PUBLIC_ prefix)
CONTACT_EMAIL=hello@yourclinic.co.uk

# ── Web3Forms — Contact Form ───────────────────────────────────────────────
# Get your access key at https://web3forms.com (Pro plan required for
# `ccemail` + reCAPTCHA verification — ~$8/month).
# PUBLIC_ prefix exposes it to the browser — safe by design.
# The key is bound to the Web3Forms dashboard form; the dashboard's
# "Recipient Emails" field defines the PRIMARY inbox.
PUBLIC_WEB3FORMS_KEY=your-access-key-here

# CC list — additional recipients copied on every submission.
# Web3Forms expects field name `ccemail` and SEMICOLON separator.
# (NOT `cc`, NOT `bcc`, NOT `to`. Comma-separated values are auto-
# normalised to semicolons in code so legacy values keep working.)
# Example: PUBLIC_CLIENT_EMAIL=client@inbox.co.uk; agency@hmdg.co.uk
# PUBLIC_ means it's visible in HTML source — only use email addresses
# that already appear publicly on the contact page.
PUBLIC_CLIENT_EMAIL=client@inbox.co.uk; agency@hmdg.co.uk

# ── Google reCAPTCHA v3 — Spam Protection ──────────────────────────────────
# Register a v3 site at https://www.google.com/recaptcha/admin
# PUBLIC_ prefix exposes the Site Key to the browser — this is correct.
# The SECRET key goes in the Web3Forms dashboard (never in code).
# Required if Web3Forms reCAPTCHA enforcement is enabled.
PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key-here

# ── IMPORTANT: Cloudflare Pages env vars ──────────────────────────────────
# All four PUBLIC_* values above must also be set in:
#   Cloudflare Pages → Settings → Variables and Secrets → BUILD scope
# (NOT Runtime scope — these are baked at build time).
#
# Cloudflare does NOT auto-rebuild when env vars change. After saving:
#   Deployments → latest deployment → "Retry deployment"
# Without that retry, the form keeps using the old build's values.

# ── Cookie Consent / Booking Tracker ──────────────────────────────────────
# GA4 Measurement Protocol API Secret
# Find in: GA4 → Admin → Data Streams → select stream → Measurement Protocol API secrets
GA4_API_SECRET=

# GA4 Measurement ID — must match gtagId in src/config/cookie-consent.config.ts
GA4_MEASUREMENT_ID=

# The site's full production URL — used to validate API route request origins
SITE_ORIGIN=https://yourclinic.co.uk
