---
/**
 * index.astro — HMDG Base Template Design System Reference
 * ─────────────────────────────────────────────────────────
 * Internal documentation only. Not a client-facing page.
 * Every design token, component, and pattern is documented here.
 *
 * RULE: Only global CSS classes and Tailwind tokens — no new styles on this page.
 */
import "../styles/global.css";
import CookieConsent from "../components/CookieConsent.astro";
import ContactForm  from "../components/ContactForm.astro";

const colours = [
  { label: "--color-primary",       hex: "#DB003E", desc: "Main brand colour — buttons, links, accents. Change per client.",              group: "Brand"   },
  { label: "--color-primary-hover", hex: "#DD0D48", desc: "Hover state for all primary interactive elements.",                             group: "Brand"   },
  { label: "--color-accent",        hex: "#FDF2F5", desc: "Light brand tint — section backgrounds and secondary fills.",                   group: "Brand"   },
  { label: "--color-headline",      hex: "#040303", desc: "Near-black — applied to h1–h6 automatically via @layer base.",                  group: "Content" },
  { label: "--color-body",          hex: "#151515", desc: "Near-black — paragraphs and all body text.",                                    group: "Content" },
  { label: "--color-caption",       hex: "#94A3B8", desc: "Slate grey — captions, labels, meta text, secondary copy.",                    group: "Content" },
  { label: "--color-muted",         hex: "#F2F2F2", desc: "Light grey — alternating section backgrounds.",                                 group: "Surface" },
  { label: "--color-surface",       hex: "#F8FAFC", desc: "Off-white — card and form backgrounds.",                                        group: "Surface" },
  { label: "--color-border",        hex: "#E2E8F0", desc: "Subtle border and divider colour.",                                             group: "Surface" },
  { label: "--color-white",         hex: "#FFFFFF", desc: "Pure white — card surfaces, nav, modals.",                                      group: "Surface" },
  { label: "--color-black",         hex: "#000000", desc: "Pure black — use sparingly.",                                                   group: "Surface" },
  { label: "--color-hero-dark",     hex: "#0a0f1a", desc: "Deep navy-black — hero and dark footer backgrounds on legal and index pages.", group: "Surface" },
];

const buttons = [
  { cls: "btn-default",     dark: false, desc: "Primary filled. Main CTAs, hero sections, form submits. Always on a light background." },
  { cls: "btn-secondary",   dark: false, desc: "Outlined primary. Secondary actions next to btn-default. Light backgrounds only." },
  { cls: "btn-white",       dark: true,  desc: "White filled. Use on dark or brand-coloured backgrounds only." },
  { cls: "btn-transparent", dark: true,  desc: "Ghost white outline. Use on image overlays or dark sections only." },
];

const headings = [
  { tag: "h1", label: "H1", size: "clamp(2.5rem → 4.5rem)",     weight: "800", lh: "1.08", use: "Hero headlines, page titles"      },
  { tag: "h2", label: "H2", size: "clamp(2rem → 3.5rem)",       weight: "800", lh: "1.12", use: "Section headings"                 },
  { tag: "h3", label: "H3", size: "clamp(1.5rem → 2.5rem)",     weight: "700", lh: "1.2",  use: "Sub-sections, card titles"       },
  { tag: "h4", label: "H4", size: "clamp(1.25rem → 1.75rem)",   weight: "700", lh: "1.3",  use: "Feature names, labels"           },
  { tag: "h5", label: "H5", size: "clamp(1.125rem → 1.375rem)", weight: "600", lh: "1.35", use: "Eyebrow labels, small headings"  },
  { tag: "h6", label: "H6", size: "clamp(1rem → 1.125rem)",     weight: "600", lh: "1.4",  use: "Fine labels, footnote headings"  },
];

const textStyles = [
  { token: "--text-base", px: "16px", lh: "1.75", cls: "",        label: "Base",  desc: "Default body text",              sample: "This is standard body text at 16px. Line-height 1.75 for comfortable reading. Clinic websites serve patients of all ages including older adults, so readability is always the priority. Never reduce body text below 16px." },
  { token: "--text-lg",   px: "18px", lh: "1.8",  cls: "text-lg", label: "Large", desc: "Lead paragraphs, intros",       sample: "This is a lead paragraph at 18px. Use for the first paragraph in a section or anywhere you need more visual weight without a heading. Apply class .section-lead or text-lg." },
  { token: "--text-sm",   px: "15px", lh: "1.6",  cls: "text-sm", label: "Small", desc: "Captions, labels, metadata",   sample: "Small text at 15px for captions, metadata, certifications, and supporting information. Use for dates, addresses, and non-critical copy." },
];

const features = [
  { title: "HCPC Registered",   desc: "All clinicians are fully registered and hold current professional indemnity insurance." },
  { title: "4.9 Google Rating", desc: "Over 500 verified patient reviews. Trusted by the local community for over a decade." },
  { title: "Fast Results",      desc: "Most patients see measurable improvement within 2–3 sessions. No long waiting lists." },
  { title: "Personal Approach", desc: "Every treatment plan is built around your specific goals, lifestyle, and recovery needs." },
];

const navLinks = [
  { href: "#workflow",   label: "Workflow",       num: "01" },
  { href: "#colours",    label: "Colours",        num: "02" },
  { href: "#fonts",      label: "Fonts",          num: "03" },
  { href: "#typography", label: "Typography",     num: "04" },
  { href: "#body-text",  label: "Body Text",      num: "05" },
  { href: "#buttons",    label: "Buttons",        num: "06" },
  { href: "#forms",      label: "Forms",          num: "07" },
  { href: "#containers", label: "Containers",     num: "08" },
  { href: "#flex",       label: "Flex Layout",    num: "09" },
  { href: "#cards",      label: "Cards",          num: "10" },
  { href: "#combined",   label: "Example",        num: "11" },
  { href: "#utilities",  label: "Utility Classes",num: "12" },
  { href: "#tokens",     label: "Design Tokens",  num: "13" },
  { href: "#globalcss",  label: "global.css",     num: "14" },
  { href: "#images",     label: "Image Rules",    num: "15" },
  { href: "#security",   label: "Security",       num: "16" },
  { href: "#agents",     label: "Agent System",   num: "17" },
  { href: "#modes",      label: "Modes & Tiers",  num: "18" },
  { href: "#skills",     label: "Skills Library", num: "19" },
  { href: "#perfbuild",  label: "Perf & Build",   num: "20" },
  { href: "#herovideo",  label: "Hero Video",     num: "21" },
  { href: "#projectlog", label: "Project Log",    num: "22" },
  { href: "#envvars",    label: "Env Variables",  num: "23" },
  { href: "#baselayout", label: "BaseLayout",     num: "24" },
  { href: "#cookiecfg",  label: "Cookie Config",  num: "25" },
  { href: "#carousel",   label: "Carousels",      num: "26" },
  { href: "#reviews",    label: "Google Reviews", num: "27" },
  { href: "#setup",      label: "Client Setup",   num: "28" },
  { href: "#deploy",     label: "Deploy to CF",   num: "29" },
  { href: "#fallback",   label: "Fallback Redirect", num: "30" },
];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Design System — HMDG Base Template</title>
    <style>
      /* Docs page — headings render at editorial weight 400, not landing page weight */
      h1, h2, h3, h4, h5, h6 { font-weight: 400; }

      /* Typography specimen — restore natural weights inside preview wrapper */
      .type-preview h1, .type-preview h2 { font-weight: var(--font-weight-extrabold); }
      .type-preview h3, .type-preview h4 { font-weight: var(--font-weight-bold); }
      .type-preview h5, .type-preview h6 { font-weight: var(--font-weight-semibold); }

      /* Design token radius demos — border-radius set via JS CSS variable */
      .radius-demo {
        border-radius: var(--demo-radius, 0px);
      }

      /* Sidebar active link state — toggled by IntersectionObserver */
      .sidebar-link.is-active {
        color: var(--color-headline);
        background-color: var(--color-accent);
        font-weight: var(--font-weight-semibold);
      }
      .sidebar-link.is-active .sidebar-num {
        color: var(--color-headline);
      }

      /* Dark sections — hero and footer use deep navy-black token */
      .ds-dark {
        background-color: var(--color-hero-dark);
      }
    </style>
  </head>

  <body class="bg-[--color-muted] text-[--color-body]">


    <!-- ══════════════════════════════════════════════════════
         STICKY HEADER
    ══════════════════════════════════════════════════════ -->


    <!-- ══════════════════════════════════════════════════════
         TWO-COLUMN LAYOUT: Sidebar + Main
    ══════════════════════════════════════════════════════ -->
    <div class="lg:flex">


      <!-- ── LEFT SIDEBAR ──────────────────────────────────── -->
      <aside class="hidden lg:flex flex-col w-64 xl:w-72 shrink-0 sticky top-0 h-screen bg-white border-r border-[--color-border] overflow-y-auto">

        <nav class="px-4 py-6 flex-1" aria-label="Design system sections">
          <p class="text-xs font-bold text-[--color-caption] uppercase tracking-widest px-3 mb-4">Sections</p>
          <ul class="flex flex-col gap-0.5 list-none p-0 m-0">
            {navLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  data-nav={link.href.slice(1)}
                  class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-[--radius-btn] text-sm text-[--color-body] hover:text-[--color-headline] hover:bg-[--color-accent] transition-all group"
                >
                  <span class="sidebar-num text-xs font-mono font-bold text-[--color-caption] group-hover:text-[--color-headline] transition-colors w-5 shrink-0">{link.num}</span>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="px-4 py-5 border-t border-[--color-border]">
          <p class="text-xs text-[--color-caption] m-0">Internal use only</p>
          <p class="text-xs text-[--color-caption] m-0 mt-0.5">Do not distribute</p>
        </div>

      </aside>


      <!-- ── RIGHT: MAIN CONTENT ───────────────────────────── -->
      <div class="flex-1 min-w-0">


        <!-- HERO -->
        <section class="ds-dark">
          <div class="px-8 md:px-10 xl:px-14 py-16 max-w-4xl">

            <div class="flex flex-col gap-6">
              <span class="eyebrow">HMDG · Internal Documentation</span>
              <h1 class="text-white m-0">
                Welcome to Hannah's Test Site
              </h1>
              <p class="text-white/70 m-0 max-w-xl leading-relaxed">
                The global design system reference for all HMDG UK clinic websites.
                Every colour, font, heading, button, container, component, image rule, security standard, and agent workflow is documented here.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="text-xs font-semibold text-white/50 bg-white/10 border border-white/10 px-3 py-1 rounded-full">Astro 6.1</span>
                <span class="text-xs font-semibold text-white/50 bg-white/10 border border-white/10 px-3 py-1 rounded-full">Tailwind v4</span>
                <span class="text-xs font-semibold text-white/50 bg-white/10 border border-white/10 px-3 py-1 rounded-full">Cloudflare Pages</span>
                <span class="text-xs font-semibold text-white/50 bg-white/10 border border-white/10 px-3 py-1 rounded-full">12 AI Agents</span>
                <span class="text-xs font-semibold text-white/50 bg-white/10 border border-white/10 px-3 py-1 rounded-full">6 Skills</span>
                <span class="text-xs font-semibold text-white/50 bg-white/10 border border-white/10 px-3 py-1 rounded-full">v2.0.0</span>
              </div>
              <p class="text-white/50 text-sm m-0">
                Started: March 5 2026 &nbsp;·&nbsp; Last major update: April 2026
                &nbsp;·&nbsp; Do not rename any CSS variable or class unless adding new ones.
              </p>
              <div class="flex flex-wrap gap-3">
                <a href="#colours" class="btn btn-default">View Design System</a>
                <a href="#combined" class="btn btn-transparent">See Example</a>
              </div>
            </div>

            <!-- Mobile section nav pills -->
            <nav aria-label="Jump to section" class="flex flex-wrap gap-2 mt-10 pt-8 border-t border-white/10 lg:hidden">
              {navLinks.map(link => (
                <a
                  href={link.href}
                  class="text-xs font-semibold text-[--color-caption] bg-white/10 hover:bg-white/20 hover:text-[--color-caption] border border-white/10 px-3 py-1.5 rounded-[--radius-badge] transition-colors"
                >
                  {link.label}
                </a>
              ))}
            </nav>

          </div>
        </section>


        <!-- ARTICLES -->
        <main class="px-6 md:px-8 xl:px-12 py-8 flex flex-col gap-5 w-full">


          <!-- ───────────────────────────────────────────────────
               01 — WORKFLOW (Developer + Support team)
          ─────────────────────────────────────────────────────── -->
          <article id="workflow" class="bg-white border-b border-[--color-border]">

            <header class="flex items-start justify-between px-8 py-5 border-b border-[--color-border] flex-wrap gap-3">
              <div class="flex items-center gap-3">
                <span class="text-xs font-bold text-[--color-border] font-mono">01</span>
                <div class="flex flex-col gap-0.5">
                  <h5 class="m-0">Workflow</h5>
                  <p class="text-sm text-[--color-caption] m-0">How developers and the support team work with this template. Read this before anything else.</p>
                </div>
              </div>
              <span class="text-xs font-semibold text-[--color-primary] bg-[--color-accent] px-3 py-1 rounded-[--radius-badge] uppercase tracking-wide self-start">Workflow</span>
            </header>

            <div class="px-8 py-6 flex flex-col gap-8">

              <!-- Plain English -->
              <div class="p-4 bg-[--color-accent] border-l-4 border-[--color-primary] rounded-[--radius-card]">
                <p class="m-0 text-sm text-[--color-body] leading-relaxed">
                  <strong>Plain English:</strong> Two groups of people use this template. <strong>Developers</strong> use it to build a new clinic website. <strong>Support team</strong> uses it to fix tickets on a website that is already live. Both groups go through GitHub. GitHub is the single source of truth — no one edits files directly on Cloudflare.
                </p>
              </div>

              <!-- ───────── WORKFLOW A — DEVELOPER ───────── -->
              <section class="flex flex-col gap-5">

                <header class="flex flex-wrap items-center gap-3">
                  <span class="text-[10px] font-bold text-white bg-[--color-primary] px-3 py-1 rounded-[--radius-badge] uppercase tracking-wider">Workflow A</span>
                  <h5 class="m-0">Developers — building a new client site</h5>
                </header>

                <p class="m-0 text-sm text-[--color-body]">
                  Every website developer must follow these steps when starting a new clinic project. The base template is the source — every client site is a separate private repository created from a clone of this template. Never edit the base template directly for a client.
                </p>

                <!-- Numbered steps -->
                <ol class="list-none p-0 m-0 flex flex-col gap-2">
                  {[
                    { num: "01", title: "Clone the base template",      body: "Open a terminal on your local computer. Run: git clone https://github.com/felmerald-hmdg/astro-base-template-cloudflare.git PROJECT-NAME — replacing PROJECT-NAME with the client's name." },
                    { num: "02", title: "Customise locally",            body: "Open the cloned folder in your editor. Customise per the Client Setup Checklist (Section 27 — Phase 2). Run npm install, npm run dev, then test locally." },
                    { num: "03", title: "Create a NEW private repo on GitHub", body: 'Go to github.com → "New repository". Name it exactly the same as the client (PROJECT-NAME). Set it to PRIVATE. Do NOT initialise with a README — the cloned template already has one.' },
                    { num: "04", title: "Point the local clone at the new repo", body: "Back in the terminal, inside the cloned folder, run: git remote set-url origin https://github.com/YOUR-ORG/PROJECT-NAME.git — then git push -u origin main." },
                    { num: "05", title: "Deploy to Cloudflare Pages",   body: "Follow the step-by-step deployment guide in Section 28. The first deploy connects the new private repo to a Cloudflare Pages project. After that, every push to main auto-deploys." },
                  ].map(s => (
                    <li class="flex items-start gap-4 p-4 bg-[--color-muted] border border-[--color-border] rounded-[--radius-card]">
                      <span class="flex items-center justify-center w-9 h-9 shrink-0 rounded-full bg-[--color-primary] text-white font-bold text-xs font-mono">{s.num}</span>
                      <div class="flex-1 min-w-0">
                        <p class="m-0 text-sm font-semibold text-[--color-headline]">{s.title}</p>
                        <p class="m-0 text-xs text-[--color-body] leading-relaxed">{s.body}</p>
                      </div>
                    </li>
                  ))}
                </ol>

                <!-- Diagram A -->
                <div class="border-t border-[--color-border] pt-5">
                  <p class="text-xs font-bold text-[--color-caption] uppercase tracking-widest m-0 mb-4">Visual flow</p>
                  <div class="max-w-xl mx-auto flex flex-col items-stretch">

                    <!-- Box 1 -->
                    <div class="flex items-center gap-4 p-4 bg-white border-2 border-[--color-primary] rounded-[--radius-card]">
                      <div class="flex items-center justify-center w-12 h-12 shrink-0 rounded-full bg-[--color-accent] text-[--color-primary]">
                        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <p class="m-0 text-xs font-bold text-[--color-caption] uppercase tracking-wide">Source</p>
                        <p class="m-0 text-sm font-bold text-[--color-headline]">HMDG Base Template</p>
                        <p class="m-0 text-xs text-[--color-body]">Public template repo on GitHub</p>
                      </div>
                    </div>

                    <!-- Arrow with label -->
                    <div class="flex flex-col items-center py-2">
                      <div class="w-px h-4 bg-[--color-border]"></div>
                      <span class="px-3 py-1 bg-[--color-accent] text-[--color-primary] text-[10px] font-mono font-bold uppercase tracking-wider rounded-[--radius-badge]">git clone</span>
                      <div class="w-px h-4 bg-[--color-border]"></div>
                      <svg class="w-4 h-4 text-[--color-border]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"></polyline>
                      </svg>
                    </div>

                    <!-- Box 2 -->
                    <div class="flex items-center gap-4 p-4 bg-white border border-[--color-border] rounded-[--radius-card]">
                      <div class="flex items-center justify-center w-12 h-12 shrink-0 rounded-full bg-[--color-muted] text-[--color-headline]">
                        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                          <line x1="8" y1="21" x2="16" y2="21"></line>
                          <line x1="12" y1="17" x2="12" y2="21"></line>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <p class="m-0 text-xs font-bold text-[--color-caption] uppercase tracking-wide">Step 2</p>
                        <p class="m-0 text-sm font-bold text-[--color-headline]">Developer's local computer</p>
                        <p class="m-0 text-xs text-[--color-body]">Customise per Client Setup Checklist (Section 27)</p>
                      </div>
                    </div>

                    <div class="flex flex-col items-center py-2">
                      <div class="w-px h-4 bg-[--color-border]"></div>
                      <span class="px-3 py-1 bg-[--color-accent] text-[--color-primary] text-[10px] font-mono font-bold uppercase tracking-wider rounded-[--radius-badge]">git push</span>
                      <div class="w-px h-4 bg-[--color-border]"></div>
                      <svg class="w-4 h-4 text-[--color-border]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"></polyline>
                      </svg>
                    </div>

                    <!-- Box 3 -->
                    <div class="flex items-center gap-4 p-4 bg-white border border-[--color-border] rounded-[--radius-card]">
                      <div class="flex items-center justify-center w-12 h-12 shrink-0 rounded-full bg-[--color-muted] text-[--color-headline]">
                        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                          <path d="M9 9h6v6H9z"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <p class="m-0 text-xs font-bold text-[--color-caption] uppercase tracking-wide">Step 3</p>
                        <p class="m-0 text-sm font-bold text-[--color-headline]">New PRIVATE GitHub repo</p>
                        <p class="m-0 text-xs text-[--color-body]">Named "PROJECT-NAME" (the client)</p>
                      </div>
                    </div>

                    <div class="flex flex-col items-center py-2">
                      <div class="w-px h-4 bg-[--color-border]"></div>
                      <span class="px-3 py-1 bg-[--color-accent] text-[--color-primary] text-[10px] font-mono font-bold uppercase tracking-wider rounded-[--radius-badge]">connect (Section 28)</span>
                      <div class="w-px h-4 bg-[--color-border]"></div>
                      <svg class="w-4 h-4 text-[--color-border]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"></polyline>
                      </svg>
                    </div>

                    <!-- Box 4 - destination -->
                    <div class="flex items-center gap-4 p-4 bg-[--color-primary]/8 border-2 border-[--color-primary] rounded-[--radius-card]">
                      <div class="flex items-center justify-center w-12 h-12 shrink-0 rounded-full bg-[--color-primary] text-white">
                        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <p class="m-0 text-xs font-bold text-[--color-primary] uppercase tracking-wide">Live</p>
                        <p class="m-0 text-sm font-bold text-[--color-headline]">Cloudflare Pages</p>
                        <p class="m-0 text-xs text-[--color-body]">Auto-deploys on every push to main</p>
                      </div>
                    </div>

                  </div>
                </div>

              </section>


              <!-- ───────── WORKFLOW B — SUPPORT TEAM ───────── -->
              <section class="flex flex-col gap-5 border-t-2 border-[--color-border] pt-8">

                <header class="flex flex-wrap items-center gap-3">
                  <span class="text-[10px] font-bold text-white bg-[--color-headline] px-3 py-1 rounded-[--radius-badge] uppercase tracking-wider">Workflow B</span>
                  <h5 class="m-0">Intercom support team — fixing tickets on a live site</h5>
                </header>

                <p class="m-0 text-sm text-[--color-body]">
                  Once a client site is live, ongoing support is handled by the Intercom team. Every support team member must have a GitHub account with access to the client's repository. Fixes are made on a feature branch, opened as a pull request, and merged to <code class="code-label">main</code> only by Fel. Cloudflare auto-deploys after the merge.
                </p>

                <!-- Numbered steps -->
                <ol class="list-none p-0 m-0 flex flex-col gap-2">
                  {[
