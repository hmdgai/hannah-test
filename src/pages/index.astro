---
/**
 * index.astro — Meridian Health homepage
 * ─────────────────────────────────────────────────────────
 * Seven-section homepage per brief Section 5.1. Alternating
 * cream / deep-dark rhythm, lime accents, oversized display
 * type, geometric SVG illustrations only.
 *
 * Build order on this page (top → bottom):
 *   1. Dark hero (Orbital SVG + H1 + dual CTA)
 *   2. Trust strip on dark
 *   3. The Problem on cream (5 pain points)
 *   4. Stats strip on dark (4 numbers)
 *   5. Methodology teaser on cream (3 pillars)
 *   6. Testimonials on dark (Swiper fade carousel, 6 quotes)
 *   7. Closing CTA on cream
 */
import BaseLayout    from "../layouts/BaseLayout.astro";
import Sparkle       from "../components/svg/Sparkle.astro";
import Orbital       from "../components/svg/Orbital.astro";
import MeridianLine  from "../components/svg/MeridianLine.astro";

const trustItems = [
  "CQC Registered",
  "GMC-licensed physicians",
  "300+ active members",
  "9.6 average member rating",
];

const painPoints = [
  {
    heading: "Your annual check-up tells you nothing useful.",
    body: "A 20-minute GP appointment and a basic blood panel will not catch the things that will actually end your career — cardiovascular silent decline, early metabolic dysfunction, sleep architecture collapse, cognitive drift.",
  },
  {
    heading: "You're reactive when you can afford to be proactive.",
    body: "By the time symptoms force you to see a doctor, the window for cheap, easy intervention has usually closed. The patients with the best outcomes intervened five years before they had to.",
  },
  {
    heading: "You don't have time for the NHS pathway.",
    body: "A specialist referral that takes nine months is not a healthcare pathway. It's a queue. You don't have nine months.",
  },
  {
    heading: "You're already spending the money — badly.",
    body: "Most executives spend more on supplements, wearables, and reactive private appointments in a year than a Meridian membership costs. Without a physician coordinating any of it.",
  },
  {
    heading: "Generic concierge medicine is just a faster GP.",
    body: "Paying for fast access to the same generalist with the same training, the same protocols, and the same 12-minute appointment is not the answer. You need a different methodology.",
  },
];

const stats = [
  { number: "300+",    caption: "active members" },
  { number: "£8,500",  caption: "from / membership / year" },
  { number: "94%",     caption: "retention rate" },
  { number: "4hr",     caption: "average response time" },
];

const pillars = [
  {
    num: "01",
    heading: "Diagnose deeply",
    body: "We build a baseline using advanced diagnostics most clinics don't have access to. Cardiac CT, advanced lipid panels, continuous glucose monitoring, sleep architecture studies, cognitive baselining.",
  },
  {
    num: "02",
    heading: "Intervene precisely",
    body: "Once we know what's actually happening in your body, we intervene on the specific variables that matter — not a generic wellness plan.",
  },
  {
    num: "03",
    heading: "Stay close",
    body: "Your physician is reachable by direct line. Quarterly check-ins are the floor, not the ceiling.",
  },
];

const testimonials = [
  {
    author: "Marcus K.",
    rating: 5,
    quote: "Spent 15 years going to Harley Street private GPs and the difference here is the methodology, not the office. Dr Holloway picked up something on my last bloods that two previous doctors had missed.",
    when: "2 weeks ago",
  },
  {
    author: "Sarah L.",
    rating: 5,
    quote: "The Executive Assessment was the first day I've ever spent at a doctor's that felt thorough. I left with a list of specific things to actually do, not vague advice.",
    when: "1 month ago",
  },
  {
    author: "James T.",
    rating: 5,
    quote: "Their on-call line is the real value. Called at 9pm on a Sunday from Singapore and had a physician on the phone in under ten minutes.",
    when: "1 month ago",
  },
  {
    author: "Priya M.",
    rating: 5,
    quote: "Dr Whitfield's discovery call is unlike any sales call. She told me my situation didn't actually warrant the full membership and to come back in two years. Won me as a customer there and then.",
    when: "2 months ago",
  },
  {
    author: "Daniel R.",
    rating: 4,
    quote: "Pricey, and not for everyone. But for what we do and the hours we work, the proactive approach is the only thing that's worked for me. Three years in now.",
    when: "3 months ago",
  },
  {
    author: "Olivia C.",
    rating: 5,
    quote: "The mental wellness side gets overlooked when people talk about Meridian. James saved my year, honestly.",
    when: "4 months ago",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  name: "Meridian Health",
  description:
    "Concierge medicine for founders, executives, and professionals. Annual diagnostic deep-dives, 24/7 physician access, proactive longevity protocols. Mayfair, London.",
  address: {
    "@type": "PostalAddress",
    streetAddress: "14 South Audley Street",
    addressLocality: "Mayfair, London",
    postalCode: "W1K 1JQ",
    addressCountry: "GB",
  },
  telephone: "+44 20 7946 1840",
  email: "concierge@meridianhealth.fictitious",
  url: "https://meridian-health.pages.dev/",
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.9",
    reviewCount: 287,
  },
};
---

<BaseLayout
  title="Meridian Health — Concierge medicine for executives"
  description="Concierge medicine for founders and executives. Annual diagnostics, 24/7 physician access. Mayfair, London. From £8,500/yr."
  schema={schema}
>

  <!-- ════════════════════════════════════════════════════════════
       1. DARK HERO
       ════════════════════════════════════════════════════════════ -->
  <section class="relative bg-[--color-hero-dark] text-[--color-cream] overflow-hidden">

    <!-- Orbital backdrop — absolute, behind content -->
    <div class="absolute top-12 right-[-10%] w-[60%] max-w-[760px] opacity-70 pointer-events-none hidden lg:block" aria-hidden="true">
      <Orbital />
    </div>

    <!-- Subtle mobile orbital — smaller, top-right -->
    <div class="absolute top-6 right-[-30%] w-[80%] opacity-30 pointer-events-none lg:hidden" aria-hidden="true">
      <Orbital />
    </div>

    <div class="container-main relative py-28 lg:py-44">
      <div class="max-w-3xl flex flex-col gap-8">

        <span class="eyebrow text-[--color-primary] inline-flex items-center gap-2">
          <Sparkle size="h-3 w-3" />
          Concierge medicine · Mayfair
        </span>

        <h1 class="m-0 text-white">
          Engineering longer, better, sharper lives.
        </h1>

        <p class="m-0 text-lg lg:text-xl text-[--color-cream]/80 max-w-2xl leading-relaxed">
          Concierge medicine for founders, executives, and professionals who can't afford
          to be reactive about their health. Membership starts at £8,500 a year.
        </p>

        <div class="flex flex-wrap gap-4 mt-2">
          <a href="/book-call" class="btn btn-default">
            Book a discovery call
          </a>
          <a
            href="/membership"
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-[--radius-btn] border border-[--color-cream]/30 text-[--color-cream] text-sm font-semibold hover:border-[--color-primary] hover:text-[--color-primary] transition-colors"
          >
            View membership
          </a>
        </div>

      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════
         2. TRUST STRIP (continues on dark)
         ════════════════════════════════════════════════════════════ -->
    <div class="border-t border-white/10">
      <div class="container-main py-6">
        <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3 text-xs sm:text-sm text-[--color-cream]/80 font-medium" role="list">
          {trustItems.map((item, i) => (
            <>
              {i > 0 && (
                <li aria-hidden="true" class="text-[--color-primary]">
                  <Sparkle size="h-3 w-3" />
                </li>
              )}
              <li class="inline-flex items-center gap-2">
                <Sparkle size="h-3 w-3" color="var(--color-primary)" />
                <span>{item}</span>
              </li>
            </>
          ))}
        </ul>
      </div>
    </div>

  </section>


  <!-- ════════════════════════════════════════════════════════════
       3. THE PROBLEM (cream)
       ════════════════════════════════════════════════════════════ -->
  <section class="bg-[--color-cream]">
    <div class="container-main py-24 lg:py-36">

      <div class="max-w-4xl mb-16 lg:mb-24">
        <span class="eyebrow text-[--color-caption] mb-6 inline-block">The problem</span>
        <h2 class="m-0 text-[--color-headline]">
          Your career depends on your output. Your output depends on a body and brain you treat as an afterthought.
        </h2>
      </div>

      <ol class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12" role="list">
        {painPoints.map((point, i) => (
          <li class="border-t border-[--color-headline] pt-8 flex flex-col gap-4">
            <span class="text-sm font-mono font-semibold text-[--color-caption]">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h3 class="m-0 text-2xl lg:text-3xl font-extrabold text-[--color-headline] tracking-[-0.02em] leading-tight">
              {point.heading}
            </h3>
            <p class="m-0 text-[--color-body] leading-relaxed">
              {point.body}
            </p>
          </li>
        ))}
      </ol>

    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════
       4. STATS STRIP (dark)
       ════════════════════════════════════════════════════════════ -->
  <section class="bg-[--color-hero-dark] text-[--color-cream]">
    <div class="container-main py-24 lg:py-32">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
        {stats.map((stat) => (
          <div class="flex flex-col gap-3">
            <span class="font-heading text-5xl lg:text-7xl font-extrabold text-[--color-primary] tracking-[-0.03em] leading-none">
              {stat.number}
            </span>
            <span class="text-sm text-[--color-cream]/70 uppercase tracking-wider font-medium leading-snug">
              {stat.caption}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════
       5. METHODOLOGY TEASER (cream)
       ════════════════════════════════════════════════════════════ -->
  <section class="bg-[--color-cream]">
    <div class="container-main py-24 lg:py-36">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 mb-16 lg:mb-20 items-end">
        <div class="lg:col-span-7 flex flex-col gap-6">
          <span class="eyebrow text-[--color-caption] inline-flex items-center gap-2">
            <Sparkle size="h-3 w-3" color="var(--color-primary)" />
            The Meridian Methodology
          </span>
          <h2 class="m-0 text-[--color-headline]">
            One coordinated team. One engineered protocol.
          </h2>
        </div>
        <div class="lg:col-span-5">
          <p class="m-0 text-[--color-body] text-lg leading-relaxed">
            We replace the chaos of fragmented healthcare — your GP, your therapist, your
            nutritionist, your gym, your wearable — with one coordinated team and one
            engineered protocol. Designed around how senior careers actually work.
          </p>
          <a
            href="/methodology"
            class="inline-flex items-center gap-2 mt-6 text-sm font-semibold text-[--color-headline] border-b border-[--color-headline] hover:border-[--color-primary] hover:text-[--color-headline] pb-1 transition-colors"
          >
            Read the methodology in detail
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <ol class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8" role="list">
        {pillars.map((pillar) => (
          <li class="card bg-[--color-surface] border border-[--color-border] flex flex-col gap-5 p-8 lg:p-10">
            <span class="font-mono text-sm font-semibold text-[--color-caption]">
              {pillar.num}
            </span>
            <h3 class="m-0 text-2xl lg:text-3xl font-extrabold text-[--color-headline] tracking-[-0.02em] leading-tight">
              {pillar.heading}
            </h3>
            <p class="m-0 text-[--color-body] leading-relaxed">
              {pillar.body}
            </p>
          </li>
        ))}
      </ol>

    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════
       6. TESTIMONIALS (dark, Swiper fade carousel)
       ════════════════════════════════════════════════════════════ -->
  <section class="bg-[--color-hero-dark] text-[--color-cream]" id="testimonials">
    <div class="container-main py-24 lg:py-36">

      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12 lg:mb-20">
        <div class="flex flex-col gap-4 max-w-2xl">
          <span class="eyebrow text-[--color-primary] inline-flex items-center gap-2">
            <Sparkle size="h-3 w-3" />
            What members say
          </span>
          <h2 class="m-0 text-white">
            From founders, executives, and senior professionals.
          </h2>
        </div>
        <div class="hidden sm:flex items-center gap-2 shrink-0">
          <button
            class="meridian-prev w-12 h-12 rounded-full border border-[--color-cream]/30 text-[--color-cream] hover:border-[--color-primary] hover:text-[--color-primary] transition-colors inline-flex items-center justify-center"
            aria-label="Previous testimonial"
          >
            <span aria-hidden="true">←</span>
          </button>
          <button
            class="meridian-next w-12 h-12 rounded-full border border-[--color-cream]/30 text-[--color-cream] hover:border-[--color-primary] hover:text-[--color-primary] transition-colors inline-flex items-center justify-center"
            aria-label="Next testimonial"
          >
            <span aria-hidden="true">→</span>
          </button>
        </div>
      </div>

      <div class="swiper meridian-testimonials" aria-roledescription="carousel" aria-label="Member testimonials">
        <div class="swiper-wrapper">
          {testimonials.map((t) => (
            <article class="swiper-slide" aria-roledescription="slide">
              <div class="max-w-4xl flex flex-col gap-8">
                <div class="flex items-center gap-1" aria-label={`Rating: ${t.rating} out of 5`}>
                  {Array.from({ length: 5 }).map((_, i) => (
                    <span
                      aria-hidden="true"
                      class={i < t.rating ? "text-[--color-primary]" : "text-[--color-cream]/20"}
                    >
                      <Sparkle size="h-4 w-4" />
                    </span>
                  ))}
                </div>
                <blockquote class="m-0">
                  <p class="m-0 text-2xl lg:text-4xl font-heading font-bold text-white tracking-[-0.02em] leading-snug">
                    “{t.quote}”
                  </p>
                </blockquote>
                <footer class="flex items-center gap-4 text-sm text-[--color-cream]/70">
                  <cite class="not-italic font-semibold text-white">{t.author}</cite>
                  <span aria-hidden="true">·</span>
                  <span>{t.when}</span>
                </footer>
              </div>
            </article>
          ))}
        </div>

        <!-- Mobile pagination dots -->
        <div class="meridian-pagination sm:hidden flex items-center justify-center gap-2 mt-8"></div>
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════════════════════════
       7. CLOSING CTA (cream)
       ════════════════════════════════════════════════════════════ -->
  <section class="bg-[--color-cream]">
    <div class="container-main py-28 lg:py-44">

      <div class="max-w-4xl flex flex-col gap-8 items-start">
        <div aria-hidden="true" class="w-full max-w-[480px] mb-4">
          <MeridianLine />
        </div>
        <span class="eyebrow text-[--color-caption] inline-flex items-center gap-2">
          <Sparkle size="h-3 w-3" color="var(--color-primary)" />
          Talk to a physician
        </span>
        <h2 class="m-0 text-[--color-headline]">
          Talk to a physician, not a salesperson.
        </h2>
        <p class="m-0 text-[--color-body] text-lg lg:text-xl leading-relaxed max-w-2xl">
          All membership conversations start with a 30-minute call with Dr Whitfield.
          No sales pitch. No pressure. If we're not the right fit, she'll tell you.
        </p>
        <a href="/book-call" class="btn btn-default mt-2">
          Book a discovery call
        </a>
      </div>

    </div>
  </section>


  <!-- ── Swiper init (loaded only on this page) ──────────────────── -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
  <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <script is:inline>
    (function () {
      function init() {
        if (typeof window.Swiper === 'undefined') return;
        new window.Swiper('.meridian-testimonials', {
          effect: 'fade',
          fadeEffect: { crossFade: true },
          loop: true,
          speed: 600,
          autoHeight: true,
          slidesPerView: 1,
          navigation: {
            prevEl: '.meridian-prev',
            nextEl: '.meridian-next',
          },
          pagination: {
            el: '.meridian-pagination',
            clickable: true,
            bulletClass: 'meridian-bullet',
            bulletActiveClass: 'meridian-bullet--active',
            renderBullet: function (_, cls) {
              return '<button class="' + cls + '" aria-label="Go to testimonial"></button>';
            },
          },
          a11y: {
            prevSlideMessage: 'Previous testimonial',
            nextSlideMessage: 'Next testimonial',
          },
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>

  <style is:global>
    /* Meridian testimonial pagination bullets — sit on dark section,
       lime active, cream inactive. Local to this page. */
    .meridian-bullet {
      width: 8px;
      height: 8px;
      border-radius: 9999px;
      background: rgba(245, 242, 236, 0.25);
      border: 0;
      padding: 0;
      cursor: pointer;
      transition: background-color 0.2s ease, transform 0.2s ease;
    }
    .meridian-bullet:hover { background: rgba(245, 242, 236, 0.5); }
    .meridian-bullet--active {
      background: var(--color-primary);
      transform: scale(1.15);
    }
  </style>

</BaseLayout>
