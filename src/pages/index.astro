  <script>
    // ── Colour swatches: apply data-hex as background via JS (dynamic values) ──
    (document.querySelectorAll('[data-hex]') as NodeListOf<HTMLElement>).forEach(el => {
      const v = el.getAttribute('data-hex');
      if (!v) return;
      el.style.background = v;
      // Add a subtle border so white/light swatches are always visible
      el.style.border = '1px solid rgba(0,0,0,0.08)';
    });

    // ── Copy-to-clipboard for AI Prompt boxes ──
    (document.querySelectorAll('.copy-btn') as NodeListOf<HTMLButtonElement>).forEach(btn => {
      btn.addEventListener('click', () => {
        let el: HTMLElement | null = btn.parentElement;
        let promptEl: Element | null = null;
        while (el && !promptEl) {
          promptEl = el.querySelector('.prompt-text');
          el = el.parentElement;
        }
        if (!promptEl) return;
        const text = (promptEl.textContent ?? '').trim();

        const onSuccess = () => {
          btn.textContent = '✓ Copied';
          btn.style.color = '#4ade80';
          btn.style.borderColor = 'rgba(74,222,128,0.35)';
          btn.style.background = 'rgba(74,222,128,0.08)';
          setTimeout(() => {
            btn.textContent = 'Copy';
            btn.style.color = '';
            btn.style.borderColor = '';
            btn.style.background = '';
          }, 2000);
        };

        if (navigator.clipboard?.writeText) {
          navigator.clipboard.writeText(text).then(onSuccess).catch(() => fallbackCopy(promptEl as Element, onSuccess));
        } else {
          fallbackCopy(promptEl, onSuccess);
        }
      });
    });

    function fallbackCopy(el: Element, onSuccess: () => void) {
      const range = document.createRange();
      range.selectNodeContents(el);
      const sel = window.getSelection();
      if (!sel) return;
      sel.removeAllRanges();
      sel.addRange(range);
      try { document.execCommand('copy'); onSuccess(); } catch { /* silent */ }
      sel.removeAllRanges();
    }

    // ── Sidebar active state via IntersectionObserver ──
    const sections = document.querySelectorAll('article[id]') as NodeListOf<HTMLElement>;
    const sidebarLinks = document.querySelectorAll('[data-nav]') as NodeListOf<HTMLElement>;

    if (sections.length && sidebarLinks.length) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              sidebarLinks.forEach(link => {
                const id = link.getAttribute('data-nav');
                link.classList.toggle('is-active', id === entry.target.id);
              });
            }
          });
        },
        { rootMargin: '-20% 0px -75% 0px', threshold: 0 }
      );
      sections.forEach(s => observer.observe(s));
    }
  </script>

