---
/**
 * contact.astro
 * ─────────────────────────────────────────────────────────
 * Contact page — content to be added.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us — ClinicName"
  description="Get in touch with ClinicName. We are here to help."
>

  <!-- ── Page Hero ─────────────────────────────────────── -->
  <section class="bg-slate-900">
    <div class="container-main">
      <div class="container-inner contact-inner">
        <span class="eyebrow">Get in Touch</span>
        <h1 class="text-white m-0 mt-3">Contact Us</h1>
        <p class="m-0 mt-3 text-white/60 max-w-lg leading-relaxed">
          We would love to hear from you. Reach out and a member of our team
          will get back to you as soon as possible.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Placeholder content ───────────────────────────── -->
  <section class="bg-white">
    <div class="container-main">
      <div class="container-inner">
        <p class="text-[--color-caption]">Contact form and details will be added here.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .container-inner {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }
</style>
