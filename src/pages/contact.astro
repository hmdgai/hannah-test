---
/**
 * /contact — Meridian contact page.
 * Brief Section 5.6. Two-column layout: editorial intro on the left,
 * ContactForm on the right. Web3Forms is wired with the standard
 * HMDG ContactForm component pattern.
 */
import BaseLayout    from "../layouts/BaseLayout.astro";
import Sparkle       from "../components/svg/Sparkle.astro";
import ContactForm   from "../components/ContactForm.astro";
---

<BaseLayout
  title="Contact — Meridian Health"
  description="Book a 30-minute discovery call with Dr Whitfield. No sales pitch."
>

  <!-- Hero (dark) -->
  <section class="relative bg-[--color-hero-dark] text-[--color-cream] overflow-hidden">
    <div class="container-main py-24 lg:py-36">
      <div class="max-w-4xl flex flex-col gap-6">
        <span class="eyebrow text-[--color-orange] inline-flex items-center gap-2">
          <Sparkle size="h-3 w-3" />
          Contact
        </span>
        <h1 class="m-0 text-white">
          Talk to a physician, not a salesperson.
        </h1>
        <p class="m-0 text-lg lg:text-xl text-[--color-cream]/80 max-w-3xl leading-relaxed">
          All membership conversations start with a 30-minute discovery call with
          Dr Whitfield. No sales pitch, no pressure, no commitment. If we're not
          the right fit, she'll tell you and suggest alternatives.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact body (cream) -->
  <section class="bg-[--color-cream]">
    <div class="container-main py-24 lg:py-36">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

        <!-- Left: editorial details + NAP -->
        <div class="lg:col-span-5 flex flex-col gap-10">
          <div class="flex flex-col gap-4">
            <span class="eyebrow text-[--color-caption]">By appointment</span>
            <h2 class="m-0 text-[--color-headline] text-3xl lg:text-4xl">
              The Mayfair clinic.
            </h2>
            <address class="not-italic flex flex-col gap-1 mt-2 text-[--color-body]">
              <span>14 South Audley Street</span>
              <span>Mayfair, London W1K 1JQ</span>
            </address>
            <a
              href="tel:+442079461840"
              class="text-base font-semibold text-[--color-headline] border-b border-[--color-headline] hover:border-[--color-primary] hover:text-[--color-headline] pb-1 self-start mt-2"
            >020 7946 1840</a>
            <a
              href="mailto:concierge@meridianhealth.fictitious"
              class="text-base font-semibold text-[--color-headline] border-b border-[--color-headline] hover:border-[--color-primary] pb-1 self-start break-all"
            >concierge@meridianhealth.fictitious</a>
          </div>

          <div class="flex flex-col gap-3 border-t border-[--color-border] pt-8">
            <span class="eyebrow text-[--color-caption]">Hours</span>
            <ul class="flex flex-col gap-1.5 text-sm text-[--color-body]" role="list">
              <li class="flex justify-between gap-4"><span>Mon – Wed</span><span>08:00 – 19:00</span></li>
              <li class="flex justify-between gap-4"><span>Thursday</span><span>08:00 – 20:00</span></li>
              <li class="flex justify-between gap-4"><span>Friday</span><span>08:00 – 18:00</span></li>
              <li class="flex justify-between gap-4"><span>Saturday</span><span>09:00 – 14:00<span class="text-[--color-caption] ml-1">(members only)</span></span></li>
              <li class="flex justify-between gap-4"><span>Sunday</span><span class="text-[--color-caption]">24/7 phone line for members</span></li>
            </ul>
          </div>

          <div class="flex flex-col gap-3 border-t border-[--color-border] pt-8">
            <span class="eyebrow text-[--color-caption]">A faster route</span>
            <p class="m-0 text-[--color-body] text-base leading-relaxed">
              Already know you want the discovery call? Book it directly on the
              calendar — saves a back-and-forth.
            </p>
            <a
              href="/book-call"
              class="inline-flex items-center gap-2 mt-2 text-sm font-semibold text-[--color-headline] border-b border-[--color-headline] hover:border-[--color-primary] pb-1 self-start"
            >
              Book a discovery call directly
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <!-- Right: enquiry form -->
        <div class="lg:col-span-7 lg:col-start-6">
          <span class="eyebrow text-[--color-caption]">Or send a message</span>
          <h2 class="m-0 mt-4 mb-8 text-[--color-headline] text-3xl lg:text-4xl">
            Tell us a little, we'll come back within one working day.
          </h2>
          <ContactForm
            subjectPrefix="Meridian Health"
            brandName="Meridian Health"
            submitLabel="Send enquiry"
            id="meridian-contact"
          />
          <p class="m-0 mt-6 text-sm text-[--color-caption] leading-relaxed">
            Dr Whitfield's PA will reach out within one working day to schedule
            your call. All enquiries are read by a physician, not a sales team.
          </p>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
