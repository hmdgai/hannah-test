---
import BaseLayout         from "../../layouts/BaseLayout.astro";
import DiagnosticTemplate from "../../components/DiagnosticTemplate.astro";
import { findService, relatedServices } from "../../data/diagnostics";

const service = findService("mental-wellness")!;
const related = relatedServices("mental-wellness");
---

<BaseLayout
  title={`${service.name} — Meridian Health`}
  description={service.summary}
>
  <DiagnosticTemplate service={service} related={related} />
</BaseLayout>
