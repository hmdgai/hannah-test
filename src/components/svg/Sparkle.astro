---
/**
 * Sparkle.astro
 * ─────────────────────────────────────────────────────
 * 4-pointed diamond/kite mark with slightly concave sides.
 * Used as Meridian's recurring brand signature — in the
 * wordmark, the orbital centre, decorative dots in trust
 * strips, and accent positions throughout the site.
 *
 * Renders inline SVG, inherits currentColor by default so
 * it follows the surrounding text colour. Pass `color` to
 * override explicitly.
 *
 * Props:
 *   size   — Tailwind sizing classes (default "h-4 w-4")
 *   color  — Override fill (default "currentColor")
 *   class  — Extra classes appended to the SVG root
 */

interface Props {
  size?: string;
  color?: string;
  class?: string;
}

const {
  size = "h-4 w-4",
  color = "currentColor",
  class: extraClass = "",
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden="true"
  class:list={["inline-block shrink-0", size, extraClass]}
>
  <!-- 4-point diamond with concave (inward-curving) sides.
       Curves use a midpoint pulled toward the centre so each
       quadrant edge bows inward — gives the mark its star-like
       silhouette without being a true 4-pointed star. -->
  <path
    d="M12 1
       Q 13 9, 23 12
       Q 13 15, 12 23
       Q 11 15, 1 12
       Q 11 9, 12 1 Z"
    fill={color}
  />
</svg>
