---
/**
 * MeridianLine.astro
 * ─────────────────────────────────────────────────────
 * Geometric longitude / meridian-line illustration. Sits as a divider
 * between sections, or as a background graphic in content panels.
 *
 * A long sweeping curve crossed by perpendicular tick marks — evokes
 * a navigation / cartography motif without being literal.
 *
 * Props:
 *   accentColor  — defaults to var(--color-primary)
 *   stroke       — defaults to var(--color-caption)
 *   variant      — "horizontal" (default) or "vertical"
 *   class        — extra classes appended to the SVG root
 */

interface Props {
  accentColor?: string;
  stroke?: string;
  variant?: "horizontal" | "vertical";
  class?: string;
}

const {
  accentColor = "var(--color-primary)",
  stroke = "var(--color-caption)",
  variant = "horizontal",
  class: extraClass = "",
} = Astro.props;

const viewBox = variant === "vertical" ? "0 0 100 400" : "0 0 400 100";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={viewBox}
  fill="none"
  aria-hidden="true"
  role="presentation"
  class:list={["block w-full h-auto", extraClass]}
>
  {variant === "horizontal" && (
    <>
      <!-- Main sweeping curve -->
      <path
        d="M0 50 Q 100 10, 200 50 T 400 50"
        stroke={stroke}
        stroke-width="1"
        opacity="0.6"
      />
      <!-- Accent overlay on the curve apex -->
      <path
        d="M150 30 Q 200 10, 250 30"
        stroke={accentColor}
        stroke-width="1.5"
      />
      <!-- Tick marks -->
      <line x1="50"  y1="46" x2="50"  y2="54" stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <line x1="100" y1="40" x2="100" y2="48" stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <line x1="150" y1="32" x2="150" y2="40" stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <line x1="200" y1="28" x2="200" y2="36" stroke={accentColor} stroke-width="1" />
      <line x1="250" y1="32" x2="250" y2="40" stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <line x1="300" y1="40" x2="300" y2="48" stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <line x1="350" y1="46" x2="350" y2="54" stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <!-- Coordinate dots -->
      <circle cx="200" cy="32" r="2.5" fill={accentColor} />
    </>
  )}
  {variant === "vertical" && (
    <>
      <path
        d="M50 0 Q 10 100, 50 200 T 50 400"
        stroke={stroke}
        stroke-width="1"
        opacity="0.6"
      />
      <path
        d="M30 150 Q 10 200, 30 250"
        stroke={accentColor}
        stroke-width="1.5"
      />
      <line x1="46" y1="50"  x2="54" y2="50"  stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <line x1="40" y1="100" x2="48" y2="100" stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <line x1="32" y1="150" x2="40" y2="150" stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <line x1="28" y1="200" x2="36" y2="200" stroke={accentColor} stroke-width="1" />
      <line x1="32" y1="250" x2="40" y2="250" stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <line x1="40" y1="300" x2="48" y2="300" stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <line x1="46" y1="350" x2="54" y2="350" stroke={stroke} stroke-width="0.75" opacity="0.5" />
      <circle cx="32" cy="200" r="2.5" fill={accentColor} />
    </>
  )}
</svg>
