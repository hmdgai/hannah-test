---
/**
 * Header.astro
 * ─────────────────────────────────────────────────────
 * Global sticky navigation header. Used once in BaseLayout.astro.
 *
 * Colour rules live in global.css under .site-header /
 * .site-header-mobile — scoped CSS so the nav text + wordmark
 * render reliably regardless of any Tailwind v4 arbitrary-value
 * quirks. Markup just carries semantic classes + active-state
 * helpers per HMDG nav rules.
 */
import PlusButton from "./PlusButton.astro";

const currentPath = Astro.url.pathname;

const isActive = (href: string): boolean => {
  if (href === '/') return currentPath === '/';
  const norm = href.endsWith('/') ? href : href + '/';
  return currentPath === norm || currentPath === norm.slice(0, -1);
};
const isSection = (prefix: string): boolean => currentPath.startsWith(prefix);

const homeActive        = isActive('/');
const methodologyActive = isSection('/methodology');
const membershipActive  = isSection('/membership');
const diagnosticsActive = isSection('/diagnostics');
const insightsActive    = isSection('/insights');
const contactActive     = isActive('/contact');
---

<header class="site-header sticky top-0 z-50">
  <div class="container-main py-5 flex items-center justify-between gap-6">

    <!-- Wordmark -->
    <a href="/" class="wordmark font-heading text-lg sm:text-xl font-extrabold tracking-[-0.02em] hover:opacity-80 transition-opacity inline-flex items-center gap-2" aria-label="Meridian Health — home">
      <span>MERIDIAN</span>
      <span aria-hidden="true" class="spark text-xl sm:text-2xl leading-none">✦</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center gap-10 text-sm" aria-label="Main navigation">
      <a href="/"             class:list={[ "site-nav-item transition-colors", { "is-active": homeActive } ]}>Home</a>
      <a href="/methodology"  class:list={[ "site-nav-item transition-colors", { "is-active": methodologyActive } ]}>Methodology</a>
      <a href="/membership"   class:list={[ "site-nav-item transition-colors", { "is-active": membershipActive } ]}>Membership</a>
      <a href="/diagnostics"  class:list={[ "site-nav-item transition-colors", { "is-active": diagnosticsActive } ]}>Diagnostics</a>
      <a href="/insights"     class:list={[ "site-nav-item transition-colors", { "is-active": insightsActive } ]}>Insights</a>
      <a href="/contact"      class:list={[ "site-nav-item transition-colors", { "is-active": contactActive } ]}>Contact</a>
    </nav>

    <!-- Right side: CTA + Hamburger -->
    <div class="flex items-center gap-3">
      <PlusButton
        href="/book-call"
        variant="blue"
        label="Book a discovery call"
        class="hidden md:inline-flex whitespace-nowrap"
      />

      <button
        class="lg:hidden flex flex-col gap-1.5 p-2 -mr-2"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="mobile-menu-toggle"
      >
        <span class="hamburger-line block w-6 h-0.5"></span>
        <span class="hamburger-line block w-6 h-0.5"></span>
        <span class="hamburger-line block w-6 h-0.5"></span>
      </button>
    </div>

  </div>

  <!-- Mobile Menu Drawer -->
  <div id="mobile-menu" class="site-header-mobile lg:hidden hidden" aria-hidden="true">
    <nav class="container-main py-6 flex flex-col gap-4 text-base font-medium" aria-label="Mobile navigation">
      <a href="/"             class:list={[ "mobile-nav-item site-nav-item transition-colors py-2", { "is-active": homeActive } ]}>Home</a>
      <a href="/methodology"  class:list={[ "mobile-nav-item site-nav-item transition-colors py-2", { "is-active": methodologyActive } ]}>Methodology</a>
      <a href="/membership"   class:list={[ "mobile-nav-item site-nav-item transition-colors py-2", { "is-active": membershipActive } ]}>Membership</a>
      <a href="/diagnostics"  class:list={[ "mobile-nav-item site-nav-item transition-colors py-2", { "is-active": diagnosticsActive } ]}>Diagnostics</a>
      <a href="/insights"     class:list={[ "mobile-nav-item site-nav-item transition-colors py-2", { "is-active": insightsActive } ]}>Insights</a>
      <a href="/contact"      class:list={[ "mobile-nav-item site-nav-item transition-colors py-2", { "is-active": contactActive } ]}>Contact</a>
      <PlusButton href="/book-call" variant="blue" label="Book a discovery call" class="self-start mt-2" />
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      menu.setAttribute('aria-hidden', String(isOpen));
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>
