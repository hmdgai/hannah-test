---
/**
 * BaseLayout.astro
 * ---------------------------------------------------------
 * The single shared wrapper for every page on the site.
 * Import your global CSS here once -- it applies everywhere.
 *
 * NOINDEX DEFAULTS TO TRUE.
 *   The base template ships in noindex mode so client clones cannot
 *   accidentally appear in Google before the site is ready. Permanent-
 *   noindex pages (thank-you, 404) still pass `noindex={true}` explicitly
 *   so the flag survives the eventual default flip.
 *
 *   When the user says "go live" / "index the site" / "remove noindex"
 *   flip the default below to `false`. Don't flip it for normal work.
 *
 * Props:
 *   title              -- <title> tag content (overridden by CMS metaTitle when present)
 *   description        -- meta description for SEO (overridden by CMS when present)
 *   noindex            -- defaults to TRUE; pass false explicitly to index a page
 *   heroImage          -- absolute path to the LCP hero image (desktop preload)
 *   heroImageMobile    -- absolute path to the smaller mobile hero image
 *                         Renders dual <link rel="preload" media="..."> so
 *                         each device only fetches the variant it needs.
 *   schema             -- optional JSON-LD object (or array) to inject
 *                         as <script type="application/ld+json">
 *   seo                -- optional page-level SEO fields from Sanity CMS
 *                         (overrides Default SEO field-by-field)
 */
import type { PageSEO } from '../lib/seo';
import { getSEO, getTrackingCodes } from '../lib/seo';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  heroImage?: string;
  heroImageMobile?: string;
  schema?: object | object[];
  seo?: PageSEO;
}

const {
  title,
  description = "Professional clinic providing expert care in the UK.",
  noindex = true,
  heroImage,
  heroImageMobile,
  schema,
  seo: pageSeo,
} = Astro.props;

// -- CMS-driven SEO + tracking -------------------------------------------
const resolvedSeo = await getSEO(pageSeo);
const tracking    = await getTrackingCodes();

// Resolved values: page prop -> CMS -> fallback
const pageTitle       = resolvedSeo.metaTitle || title;
const pageDescription = resolvedSeo.metaDescription || description;
const socialTitle      = resolvedSeo.socialTitle || pageTitle;
const socialDescription = resolvedSeo.socialDescription || pageDescription;
const ogImageUrl       = resolvedSeo.ogImageUrl || '';
// noindex: explicit prop wins, then CMS, then default true
const isNoindex = noindex === true || resolvedSeo.noindex;

// Canonical / OG URL.
const baseOrigin = Astro.site ? Astro.site.origin : Astro.url.origin;
const fullUrl    = baseOrigin + Astro.url.pathname;

import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ReviewsSection from "../components/ReviewsSection.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { cookieConsentConfig } from "../config/cookie-consent.config";

const cfg = cookieConsentConfig;

// Tracking: CMS values take precedence, env-var config is fallback
const gtmId     = tracking.gtmId || cfg.gtmId;
const gtagId    = tracking.ga4MeasurementId || cfg.gtagId;
const pixelId   = tracking.metaPixelId;
const gscVerify = tracking.gscVerification;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {heroImage && heroImageMobile && (
      <>
        <link rel="preload" as="image" href={heroImage} media="(min-width: 768px)" fetchpriority="high" />
        <link rel="preload" as="image" href={heroImageMobile} media="(max-width: 767px)" fetchpriority="high" />
      </>
    )}
    {heroImage && !heroImageMobile && (
      <link rel="preload" as="image" href={heroImage} fetchpriority="high" />
    )}

    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />

    <title>{pageTitle}</title>
    {isNoindex && <meta name="robots" content="noindex, nofollow" />}

    {gscVerify && (
      <meta name="google-site-verification" content={gscVerify} />
    )}

    <link rel="canonical" href={fullUrl} />

    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:locale" content="en_GB" />
    {ogImageUrl && (
      <meta property="og:image" content={ogImageUrl} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    {ogImageUrl && (
      <meta name="twitter:image" content={ogImageUrl} />
    )}

    {schema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)}></script>
    )}

    <script is:inline define:vars={{ _ccmPolicyVersion: cfg.policyVersion, _ccmCookieName: cfg.cookieName }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      gtag('consent', 'default', {
        analytics_storage:       'denied',
        ad_storage:              'denied',
        ad_user_data:            'denied',
        ad_personalization:      'denied',
        functionality_storage:   'denied',
        personalization_storage: 'denied',
        security_storage:        'granted',
        wait_for_update:         500,
      });

      (function () {
        try {
          var raw = document.cookie.split(';').find(function (c) {
            return c.trim().startsWith(_ccmCookieName + '=');
          });
          if (raw) {
            var stored = JSON.parse(decodeURIComponent(raw.split('=').slice(1).join('=')));
            if (stored && stored.policyVersion === _ccmPolicyVersion) {
              gtag('consent', 'update', {
                analytics_storage:       stored.analytics   ? 'granted' : 'denied',
                ad_storage:              stored.marketing   ? 'granted' : 'denied',
                ad_user_data:            stored.marketing   ? 'granted' : 'denied',
                ad_personalization:      stored.marketing   ? 'granted' : 'denied',
                functionality_storage:   stored.functional  ? 'granted' : 'denied',
                personalization_storage: stored.functional  ? 'granted' : 'denied',
              });
            }
          }
        } catch (e) {}
      })();
    </script>

    {gtmId && (
      <script is:inline define:vars={{ _gtmId: gtmId }}>
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });

        var loaded = false;
        function loadGtm() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement('script');
          s.async = true;
          s.src   = 'https://www.googletagmanager.com/gtm.js?id=' + _gtmId;
          (document.head || document.body).appendChild(s);
        }

        var INTERACTION_EVENTS = ['mouseenter', 'touchstart', 'scroll', 'keydown'];
        function onInteraction() {
          loadGtm();
          INTERACTION_EVENTS.forEach(function (ev) {
            window.removeEventListener(ev, onInteraction, { passive: true });
          });
        }
        INTERACTION_EVENTS.forEach(function (ev) {
          window.addEventListener(ev, onInteraction, { passive: true });
        });

        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(loadGtm, { timeout: 10000 });
        } else {
          window.setTimeout(loadGtm, 6000);
        }
      </script>
    )}

    {!gtmId && gtagId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gtagId}`}></script>
        <script is:inline define:vars={{ _gtagId: gtagId, _adsId: cfg.adsConversionId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', _gtagId);
          if (_adsId) {
            gtag('config', _adsId);
          }
        </script>
      </>
    )}

    {gtmId && cfg.adsConversionId && (
      <script is:inline define:vars={{ _adsId: cfg.adsConversionId }}>
        window.HMDG_ADS_CONVERSION_ID = _adsId;
      </script>
    )}

    {pixelId && (
      <script is:inline define:vars={{ _pixelId: pixelId }}>
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', _pixelId);
        fbq('track', 'PageView');
      </script>
    )}

    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Content-Security-Policy" content="
      default-src 'self';
      script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://maps.googleapis.com https://www.google.com https://www.gstatic.com https://connect.facebook.net;
      style-src 'self' 'unsafe-inline';
      font-src 'self';
      img-src 'self' data: https://images.unsplash.com https://maps.gstatic.com https://maps.googleapis.com https://*.googleapis.com https://cdn.sanity.io https://www.facebook.com;
      media-src 'self';
      frame-src 'self' https://www.google.com https://*.cliniko.com;
      connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://region1.google-analytics.com https://api.web3forms.com https://www.google.com https://*.api.sanity.io https://*.apicdn.sanity.io https://cdn.sanity.io https://www.facebook.com;
      object-src 'none';
      base-uri 'self';
      form-action 'self';
      upgrade-insecure-requests;
    " />
  </head>
  <body class="bg-[--color-cream] text-[--color-body] antialiased">

    <Header />

    <main>
      <slot />
    </main>

    <ReviewsSection />

    <Footer />

    <CookieConsent />

    {gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        />
      </noscript>
    )}

    {pixelId && (
      <noscript>
        <img
          height="1"
          width="1"
          style="display:none"
          src={`https://www.facebook.com/tr?id=${pixelId}&ev=PageView&noscript=1`}
          alt=""
        />
      </noscript>
    )}

  </body>
</html>
