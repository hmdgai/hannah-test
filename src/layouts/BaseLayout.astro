---
/**
 * BaseLayout.astro
 * ─────────────────────────────────────────────────────
 * The single shared wrapper for every page on the site.
 * Import your global CSS here once — it applies everywhere.
 *
 * Props:
 *   title       — <title> tag content
 *   description — meta description for SEO
 */
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Professional clinic providing expert care in the UK.",
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- ── Google Fonts ─────────────────────────────────────────
         Inter Tight — headings (compact, strong, high impact)
         Inter        — body text (comfortable, highly readable)

         Both loaded in a single request for performance.
         Weights: 400 (normal) · 500 (medium) · 600 (semibold)
                  700 (bold) · 800 (extrabold)

         GDPR / Production note:
         For live UK clinic sites, consider self-hosting these
         fonts via @fontsource packages to avoid Google tracking:
           npm install @fontsource/inter @fontsource/inter-tight
         Then import in global.css instead of loading from CDN.
    ──────────────────────────────────────────────────────────── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Inter+Tight:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- ── Security meta tags ────────────────────────────────────
         These provide baseline security on any host.
         For stronger enforcement, use HTTP headers via:
           - public/_headers  (Netlify)
           - vercel.json      (Vercel)
    ──────────────────────────────────────────────────────────── -->
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-Frame-Options" content="SAMEORIGIN" />
    <meta http-equiv="Permissions-Policy" content="camera=(), microphone=(), geolocation=(), payment=()" />
    <meta http-equiv="Content-Security-Policy" content="
      default-src 'self';
      script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://maps.googleapis.com;
      style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
      font-src 'self' https://fonts.gstatic.com;
      img-src 'self' data: https://images.unsplash.com https://maps.gstatic.com https://maps.googleapis.com https://*.googleapis.com;
      frame-src 'self' https://www.google.com https://*.cliniko.com;
      connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://region1.google-analytics.com;
      object-src 'none';
      base-uri 'self';
      form-action 'self';
      upgrade-insecure-requests;
    " />
  </head>
  <body class="bg-white text-slate-600 antialiased">

    <!-- ── Header / Nav ─────────────────────────────────── -->
    <header class="sticky top-0 z-50 bg-white border-b border-[--color-border] shadow-[--shadow-nav]">
      <div class="container px-[--spacing-section-x] py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-[--color-primary]">
          ClinicName
        </a>
        <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-[--color-body]">
          <a href="#services" class="hover:text-[--color-primary] transition-colors">Services</a>
          <a href="#testimonials" class="hover:text-[--color-primary] transition-colors">Reviews</a>
          <a href="#team" class="hover:text-[--color-primary] transition-colors">Team</a>
          <a href="#contact" class="hover:text-[--color-primary] transition-colors">Contact</a>
        </nav>
        <a href="#contact" class="btn btn-default">
          Book Now
        </a>
      </div>
    </header>

    <!-- ── Page Content ──────────────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ══════════════════════════════════════════════════
         FOOTER
    ══════════════════════════════════════════════════ -->
    <footer class="bg-[--color-headline]">

      <!-- ── Main columns ──────────────────────────────────── -->
      <div class="px-[30px] py-16">
        <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

          <!-- Brand -->
          <div class="flex-layout flex-layout--col gap-5">
            <a href="/" class="font-heading text-xl font-bold text-white hover:text-[--color-caption] transition-colors">
              ClinicName
            </a>
            <p class="m-0 text-sm text-[--color-caption] leading-relaxed">
              Your trusted clinic, helping patients recover faster, move better,
              and live without pain. HCPC-registered and fully insured.
            </p>
            <a href="#contact" class="btn btn-white self-start">Book Now</a>
          </div>

          <!-- Quick Links -->
          <div class="flex-layout flex-layout--col gap-5">
            <span class="text-xs font-semibold text-white uppercase tracking-widest">
              Quick Links
            </span>
            <nav class="flex-layout flex-layout--col gap-3" aria-label="Footer navigation">
              <a href="/"              class="text-sm text-[--color-caption] hover:text-white transition-colors">Home</a>
              <a href="#services"      class="text-sm text-[--color-caption] hover:text-white transition-colors">Services</a>
              <a href="#team"          class="text-sm text-[--color-caption] hover:text-white transition-colors">Meet the Team</a>
              <a href="#testimonials"  class="text-sm text-[--color-caption] hover:text-white transition-colors">Patient Reviews</a>
              <a href="/contact"       class="text-sm text-[--color-caption] hover:text-white transition-colors">Contact Us</a>
            </nav>
          </div>

          <!-- Services -->
          <div class="flex-layout flex-layout--col gap-5">
            <span class="text-xs font-semibold text-white uppercase tracking-widest">
              Our Services
            </span>
            <nav class="flex-layout flex-layout--col gap-3" aria-label="Services navigation">
              <a href="#services" class="text-sm text-[--color-caption] hover:text-white transition-colors">Physiotherapy</a>
              <a href="#services" class="text-sm text-[--color-caption] hover:text-white transition-colors">Sports Injuries</a>
              <a href="#services" class="text-sm text-[--color-caption] hover:text-white transition-colors">Back &amp; Neck Pain</a>
              <a href="#services" class="text-sm text-[--color-caption] hover:text-white transition-colors">Post-Surgery Rehab</a>
              <a href="#services" class="text-sm text-[--color-caption] hover:text-white transition-colors">Injury Prevention</a>
            </nav>
          </div>

          <!-- Contact -->
          <div class="flex-layout flex-layout--col gap-5">
            <span class="text-xs font-semibold text-white uppercase tracking-widest">
              Contact
            </span>
            <div class="flex-layout flex-layout--col gap-3">
              <address class="not-italic flex-layout flex-layout--col gap-1">
                <span class="text-sm text-[--color-caption]">123 High Street</span>
                <span class="text-sm text-[--color-caption]">London, UK, EC1A 1BB</span>
              </address>
              <a href="tel:02012345678"             class="text-sm text-[--color-caption] hover:text-white transition-colors">020 1234 5678</a>
              <a href="mailto:hello@clinicname.co.uk" class="text-sm text-[--color-caption] hover:text-white transition-colors">hello@clinicname.co.uk</a>
            </div>
            <div class="flex-layout flex-layout--col gap-2">
              <span class="text-xs font-semibold text-white uppercase tracking-widest">Opening Hours</span>
              <span class="text-sm text-[--color-caption]">Mon – Fri &nbsp; 8:00am – 7:00pm</span>
              <span class="text-sm text-[--color-caption]">Saturday &nbsp;&nbsp; 9:00am – 3:00pm</span>
              <span class="text-sm text-[--color-caption]">Sunday &nbsp;&nbsp;&nbsp;&nbsp; Closed</span>
            </div>
          </div>

        </div>
      </div>

      <!-- ── Bottom bar ─────────────────────────────────────── -->
      <div class="border-t border-white/10">
        <div class="px-[30px] py-4 flex-layout flex-layout--between gap-4">

          <!-- Left: copyright + credit -->
          <div class="flex-layout items-center gap-5 flex-wrap">
            <span class="text-sm text-white">
              © Copyright HMDG {new Date().getFullYear()}
            </span>
            <span class="text-sm text-white">
              Designed &amp; Developed by
              <a
                href="https://hmdg.co.uk/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-white font-semibold hover:text-primary transition-colors"
              >HMDG</a>
            </span>
          </div>

          <!-- Right: policy links -->
          <nav class="flex-layout items-center gap-5 flex-wrap" aria-label="Legal">
            <a href="/privacy-policy"   class="text-sm text-white/70 hover:text-white transition-colors">Privacy Policy</a>
            <a href="/terms-conditions" class="text-sm text-white/70 hover:text-white transition-colors">Terms &amp; Conditions</a>
            <a href="/cookie-policy"    class="text-sm text-white/70 hover:text-white transition-colors">Cookie Policy</a>
          </nav>

        </div>
      </div>

    </footer>

  </body>
</html>
