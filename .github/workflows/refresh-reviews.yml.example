# ─────────────────────────────────────────────────────────────────
# Refresh Google Reviews — weekly cron
# ─────────────────────────────────────────────────────────────────
# Pulls fresh Google Reviews via the Places API every Monday 06:00 UTC
# and commits the updated cache file. Cloudflare Pages then auto-rebuilds.
#
# To activate:
#   1. Rename this file: refresh-reviews.yml.example  →  refresh-reviews.yml
#   2. In your GitHub repo Settings → Secrets and variables → Actions,
#      add these repository secrets:
#        - GOOGLE_PLACES_API_KEY
#        - GOOGLE_PLACE_ID
#   3. Commit + push. The workflow will run weekly (and can be triggered
#      manually via the Actions tab).
#
# Free? YES.
#   - GitHub Actions free tier: 2,000 minutes/month for public repos
#     (unlimited for public). This workflow runs <1 minute per week.
#   - Google Places API: $200/month credit covers ~10,000 calls.
#     This workflow uses 4–5 calls/month → fully free.
# ─────────────────────────────────────────────────────────────────

name: Refresh Google Reviews

on:
  schedule:
    - cron: '0 6 * * 1'   # Every Monday at 06:00 UTC
  workflow_dispatch:        # Allow manual trigger via Actions tab

# Required so the action can push the updated cache file back to main
permissions:
  contents: write

jobs:
  refresh:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '22'

      - name: Fetch reviews
        env:
          GOOGLE_PLACES_API_KEY: ${{ secrets.GOOGLE_PLACES_API_KEY }}
          GOOGLE_PLACE_ID:        ${{ secrets.GOOGLE_PLACE_ID }}
        run: node scripts/fetch-google-reviews.mjs

      - name: Commit + push if changed
        run: |
          git config user.name  "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          if git diff --quiet src/data/reviews-cache.json; then
            echo "No review changes — nothing to commit."
          else
            git add src/data/reviews-cache.json
            git commit -m "chore(reviews): refresh Google Reviews cache"
            git push
          fi
